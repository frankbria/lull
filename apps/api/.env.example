# Copy to .env and fill in. Stub source needs no key (runs offline).
LULL_AUDIO_SOURCE=stub
# Postgres DSN. Default matches docker-compose.yml; override for staging/prod (Hostinger VPS).
# LULL_DATABASE_URL=postgresql+psycopg://lull:lull@localhost:5432/lull
# Set to elevenlabs + provide a key for the real TTS round-trip:
# LULL_AUDIO_SOURCE=elevenlabs
# LULL_ELEVENLABS_API_KEY=sk-...
# LULL_ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
