# Copy to .env and fill in. Stub source needs no key (runs offline).
LULL_AUDIO_SOURCE=stub
# Postgres DSN. Default matches docker-compose.yml; override for staging/prod (Hostinger VPS).
# LULL_DATABASE_URL=postgresql+psycopg://lull:lull@localhost:5432/lull
# Set to elevenlabs + provide a key for the real TTS round-trip:
# LULL_AUDIO_SOURCE=elevenlabs
# LULL_ELEVENLABS_API_KEY=sk-...
# LULL_ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
# Where generated audio is written + dedup-cached on disk (US-008). Default ./audio_store; point
# this at a persistent volume in staging/prod. Relative paths resolve to absolute on write.
# LULL_AUDIO_STORE_DIR=audio_store

# Script generation. Stub assembles a deterministic template offline (no key). Set to claude + a key
# for the real hardened-prompt generator. Model defaults to claude-opus-4-8 (set sonnet-4-6 to save).
LULL_SCRIPT_SOURCE=stub
# LULL_SCRIPT_SOURCE=claude
# LULL_ANTHROPIC_API_KEY=sk-ant-...
# LULL_ANTHROPIC_MODEL=claude-opus-4-8

# Deployment environment. Outside dev/local/test, the app refuses to start without LULL_JWT_SECRET.
# LULL_ENVIRONMENT=production
# Auth — session JWT signing secret (MUST be a real 32B+ random value in staging/prod):
# LULL_JWT_SECRET=change-me-to-a-long-random-secret
# LULL_JWT_EXPIRE_MINUTES=43200
# OAuth audiences = your app's provider client ids (JSON lists), required to accept id_tokens:
# LULL_GOOGLE_CLIENT_IDS=["1234567890-abc.apps.googleusercontent.com"]
# LULL_APPLE_CLIENT_IDS=["com.yourorg.lull"]
